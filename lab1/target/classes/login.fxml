<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<Pane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Login_Controller">

   <children>

      <TextField fx:id="emailField" layoutX="248.0" layoutY="175.0" promptText="Email" />

      <PasswordField fx:id="passwordField" layoutX="248.0" layoutY="207.0" promptText="Password" />

      <Button layoutX="299.0" layoutY="241.0" onAction="#handleLogin" text="Login" />

      <Label fx:id="resultLabel" layoutX="280.0" layoutY="280.0" text="" />
      <Label layoutX="212.0" layoutY="179.0" text="Email" />
      <Label layoutX="190.0" layoutY="211.0" text="Password" />
      <Label layoutX="277.0" layoutY="91.0" text="Welcome ">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <Label layoutX="194.0" layoutY="135.0" text=" Please insert your email and password">
         <font>
            <Font size="15.0" />
         </font>
      </Label>
   </children>
</Pane>
